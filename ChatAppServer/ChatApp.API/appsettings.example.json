{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=ChatAppDb;Trusted_Connection=True;MultipleActiveResultSets=true;"
  },
  "Jwt": {
    "Key": "YOUR-SECRET-JWT-KEY-HERE",
    "Issuer": "ChatApp.API",
    "Audience": "ChatAppClient"
  },
  "Crypto": {
    "AesKeyBase64": "YOUR-AES-KEY-IN-BASE64"
  },
  "AllowedHosts": "*"
}
