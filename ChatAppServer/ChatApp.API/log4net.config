<?xml version="1.0" encoding="utf-8" ?>
<log4net>
	<!-- =========================== -->
	<!--   FILE APPENDER (Rolling)   -->
	<!-- =========================== -->
	<appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
		<!-- Folder and file name -->
		<file type="log4net.Util.PatternString" value="../../../Logs/chatapp.log" />
		<appendToFile value="true" />

		<!-- One log file per day -->
		<rollingStyle value="Date" />
		<datePattern value="yyyy-MM-dd'.log'" />
		<staticLogFileName value="false" />

		<!-- Format of each log line -->
		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="%date [%thread] %-5level %logger - %message%newline" />
		</layout>
	</appender>

	<!-- =========================== -->
	<!--   COLORED CONSOLE APPENDER  -->
	<!-- =========================== -->
	<appender name="ColoredConsoleAppender" type="log4net.Appender.ColoredConsoleAppender">
		<!-- Color mappings for each log level -->
		<mapping>
			<level value="DEBUG" />
			<foreColor value="Gray" />
		</mapping>
		<mapping>
			<level value="INFO" />
			<foreColor value="Green" />
		</mapping>
		<mapping>
			<level value="WARN" />
			<foreColor value="Yellow" />
		</mapping>
		<mapping>
			<level value="ERROR" />
			<foreColor value="Red" />
		</mapping>
		<mapping>
			<level value="FATAL" />
			<foreColor value="White" />
			<backColor value="Red" />
		</mapping>

		<!-- Log layout -->
		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="%date %-5level %logger - %message%newline" />
		</layout>
	</appender>

	<!-- =========================== -->
	<!--     FILTERS / LOG RULES     -->
	<!-- =========================== -->

	<!-- Suppress noisy framework logs -->
	<logger name="Microsoft">
		<level value="WARN" />
	</logger>

	<logger name="System">
		<level value="WARN" />
	</logger>

	<!-- =========================== -->
	<!--         ROOT LOGGER         -->
	<!-- =========================== -->
	<root>
		<!-- Log everything from Info and above -->
		<level value="INFO" />
		<appender-ref ref="ColoredConsoleAppender" />
		<appender-ref ref="RollingFileAppender" />
	</root>
</log4net>
